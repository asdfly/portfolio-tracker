# ============================================================
# 投资组合跟踪分析系统 - 环境变量配置模板
# ============================================================
# 使用方法:
#   1. 复制本文件为 .env:  copy .env.example .env
#   2. 填入实际配置值（不需要的变量留空即可使用默认值）
#   3. .env 文件不会被提交到 Git
# ============================================================

# ---------- 数据库 ----------
# 数据库文件路径（默认: data/database/portfolio.db）
# DATABASE_PATH=

# ---------- 持仓文件 ----------
# 通达信持仓导出目录（默认: C:\zd_zsone\T0002\export）
# TDX_EXPORT_DIR=C:\zd_zsone\T0002\export

# ---------- 邮件通知 ----------
# 启用邮件通知（true/false）
# EMAIL_ENABLED=false
# SMTP 服务器
EMAIL_SMTP_SERVER=smtp.qq.com
# SMTP 端口
EMAIL_SMTP_PORT=587
# 发件人邮箱
# EMAIL_USERNAME=
# 授权码（非登录密码）
# EMAIL_PASSWORD=
# 收件人列表（逗号分隔）
# EMAIL_RECIPIENTS=

# ---------- 企业微信通知 ----------
# 启用企业微信通知（true/false）
# WECHAT_ENABLED=false
# Webhook URL
# WECHAT_WEBHOOK_URL=

# ---------- 监控告警 ----------
# 单日跌幅告警阈值（百分比，默认 -3.0）
# ALERT_DAILY_LOSS_THRESHOLD=-3.0
# 最大回撤告警阈值（百分比，默认 -10.0）
# ALERT_DRAWDOWN_THRESHOLD=-10.0
# 告警去重间隔小时数（默认 6）
# ALERT_DEDUP_INTERVAL_HOURS=6

# ---------- 智能分析 ----------
# 启用智能建议（true/false，默认 true）
# ADVICE_ENABLED=true
# 建议最小置信度（默认 0.6）
# ADVICE_MIN_CONFIDENCE=0.6
